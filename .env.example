# TelosCore Full-Memory Build
# Copy this file to .env and edit values for local use.

# EverMemOS
EVERMEMOS_API_URL=http://localhost:1995/api/v1
EVERMEMOS_USER_ID=user_001

# Optional LLM backend (not required for current competition build)
LLM_API_BASE=http://localhost:11434/v1
LLM_API_KEY=sk-local-dummy-key
LLM_MODEL=llama3

# Optional memory tuning
TELOS_HALF_LIFE=86400
TELOS_ANNEAL_TAU=1.10
TELOS_ANNEAL_ETA=0.14
TELOS_RECENT_WINDOW=30
